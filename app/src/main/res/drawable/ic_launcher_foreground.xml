<?xml version="1.0" encoding="utf-8"?>
<!-- Foreground for the adaptive launcher icon.
     Visual concept: a ring (PPTP tunnel mouth) with an arrow passing
     through it (a packet entering the tunnel). The whole composition
     sits in the 72x72 safe zone of the 108x108 canvas to avoid being
     clipped by aggressive launcher masks (pixel-style circles etc.).
     Stroke widths kept thick so the icon stays legible at 48dp. -->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <!-- Tunnel ring (hollow circle, 25 radius, stroke 7) -->
    <path
        android:strokeColor="#FFFFFF"
        android:strokeWidth="7"
        android:fillColor="#00000000"
        android:pathData="M 54 54 m -25 0 a 25 25 0 1 0 50 0 a 25 25 0 1 0 -50 0" />

    <!-- Arrow passing through the tunnel, left → right -->
    <path
        android:fillColor="#FFFFFF"
        android:pathData="M 36 54 L 60 54 L 60 48 L 74 54 L 60 60 L 60 54 Z" />
</vector>
