# Copy this file to `keystore.properties` (which is gitignored) and fill in
# real values to enable release signing.
#
# Generate a keystore once with:
#   keytool -genkey -v -keystore release.jks -keyalg RSA -keysize 4096 \
#           -validity 36500 -alias pptp-release
#
# Then place the .jks somewhere outside the repo (or inside but trust .gitignore)
# and point storeFile at it.

storeFile=/absolute/path/to/release.jks
storePassword=CHANGE_ME
keyAlias=pptp-release
keyPassword=CHANGE_ME
